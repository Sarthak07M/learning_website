<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="google-adsense-account" content="ca-pub-6731641895607660">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6731641895607660" crossorigin="anonymous"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Select a subject to access notes, resources, and academic support for your branch and semester.">
    <meta name="keywords" content="subjects, notes, study materials, engineering subjects, semester resources">
    <meta name="robots" content="index, follow">
    <meta name="theme-color" content="#0a0a0a">
    <title>IET Resources | Select Subject</title>
    <link rel="stylesheet" href="/cssfiles/faculty.css">
</head>
<body>
    <!-- Animated Background -->
    <div class="bg-animation">
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
    </div>

    <!-- Navigation -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo">
                <span class="logo-text">IET Resources</span>
                <div class="logo-glow"></div>
            </div>
            <ul class="nav-menu">
                <li><a href="/htmlfiles/index.html" class="nav-link">Home</a></li>
                <li><a href="/htmlfiles/about.html" class="nav-link">About Us</a></li>
                <li><a href="/htmlfiles/contact.html" class="nav-link">Contact Us</a></li>
                <li><a href="/htmlfiles/privacy.html" class="nav-link">Privacy Policy</a></li>
                <li><a href="/htmlfiles/team.html" class="nav-link">Team</a></li>
                <li><a href="/htmlfiles/branch.html" class="nav-link">Branches</a></li>
                <li><a href="/htmlfiles/faculty.html" class="nav-link active">Subjects</a></li>
            </ul>
            <div class="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </nav>

    <!-- Subjects Section -->
    <section id="subjects" class="subjects">
        <div class="subjects-header">
            <h2 class="subjects-title">
                Your <span class="gradient-text">Subjects</span>
            </h2>
            <p class="selected-info">
                <span id="selected-branch"><%= branch || 'Select a branch' %></span> • 
                <span id="selected-semester"><% if (semester) { %>Semester <%= semester %><% } else { %>Select a semester<% } %></span>
            </p>
            <div class="content-highlight" style="max-width: 860px; margin: 1rem auto 0;">
                Pick a subject to see the exact resource set for revision, exam practice, and semester planning.
            </div>
        </div>

        <div class="subjects-grid">
            <% if (subjects && subjects.length) { %>
                <% subjects.forEach(function(sub){ %>
                    <div class="subject-card" data-subject="<%= sub.name %>" data-code="<%= sub.code %>">
                        <div class="card-bg"></div>
                        <div class="card-code"><%= sub.code %></div>
                        <h3 class="card-title"><%- sub.name.toUpperCase().split(' ').join('<br>') %></h3>
                        <div class="card-info">
                            <p class="subject-code"><%= sub.code %></p>
                            <p class="subject-name"><%= sub.name %></p>
                            <div class="contributors">
                                <span class="contributor"><%= sub.faculty %></span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p class="no-subjects">No subjects found for <%= branch %> semester <%= semester %></p>
            <% } %>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-content">
            <div class="footer-logo">
                <span>IET Resources</span>
            </div>
            <div class="footer-links">
                <a href="/htmlfiles/about.html">About Us</a>
                <a href="/htmlfiles/contact.html">Contact Us</a>
                <a href="/htmlfiles/privacy.html">Privacy Policy</a>
                <a href="#team">Team</a>
                <a href="/htmlfiles/branch.html">Branches</a>
                <a href="/htmlfiles/faculty.html">Subjects</a>
                <a href="#contribute">Contribute</a>
            </div>
            <div class="footer-social">
                <p>&copy; 2026 IET Resources. Subject-wise resources for exam revision.</p>
            </div>
        </div>
    </footer>

    <script src="/jsfiles/faculty.js"></script>
</body>
</html>
